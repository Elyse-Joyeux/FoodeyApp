{
  "name": "foodey",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build": "npm run build:frontend",
    "preview": "npm run preview:frontend",
    "dev:frontend": "cd frontend && vite --host 127.0.0.1",
    "build:frontend": "cd frontend && vite build",
    "preview:frontend": "cd frontend && vite preview",
    "dev:backend": "node --watch backend/main.js",
    "start:backend": "node backend/main.js",
    "typecheck": "tsc -p tsconfig.frontend.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^8.9.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.14.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.15"
  }
}
